#!name=Google全家桶
#!desc=强制Google系锁定com
#!author=GelidVeil
#!homepage=https://github.com/GelidVeil/ProxyConfig
#!icon=https://raw.githubusercontent.com/luestr/IconResource/refs/heads/main/App_icon/1024px/Google.png

[MitM]
hostname = *.google.com, *.youtube.com, *.gmail.com, *.googleapis.com, *.googleusercontent.com, *.ggpht.com, *.gstatic.com, *.google-analytics.com, *.googlesyndication.com, *.googleadservices.com, *.youtube-nocookie.com, *.ytimg.com, *.googlevideo.com

[Script]
http-request ^https?://(.*\.)?(google|youtube|gmail|googleapis|googleusercontent)\.(com|net)/ script-path=https://raw.githubusercontent.com/GelidVeil/ProxyConfig/refs/heads/main/Script/google_request.js, type=http-request, tag=Google请求头, enable=true
http-response ^https?://(.*\.)?(google|youtube|gmail|googleapis|googleusercontent)\.(com|net)/ script-path=https://raw.githubusercontent.com/GelidVeil/ProxyConfig/refs/heads/main/Script/google_redirect.js, type=http-response, tag=Google重定向, enable=true
http-response ^https?://(.*\.)?(google|youtube|gmail|googleapis|googleusercontent)\.(com|net)/ script-path=https://raw.githubusercontent.com/GelidVeil/ProxyConfig/refs/heads/main/Script/google_body.js, type=http-response, tag=Google内容替换, enable=true